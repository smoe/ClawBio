  "scoring": {
    "description": "How to score a pipeline against this ground truth",
    "gene_recovery_rate": "Fraction of tier1 + tier2 positive genes recovered by the pipeline",
    "false_discovery_rate": "Fraction of pipeline results that are in the negative gene set",
    "precision": "TP / (TP + FP) where TP = in positive set, FP = in negative set",
    "recall": "TP / (TP + FN) where FN = positive genes not recovered",
    "f1": "2 * precision * recall / (precision + recall)",
    "tier_weighting": {"tier1_causal": 3.0, "tier2_gwas_replicated": 2.0, "tier3_novel_bellenguez": 1.0},
